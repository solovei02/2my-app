      "**/@react-native-community/**"
    ]
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "^4.4.0"
  }
}
